{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lineage-skill.local/schemas/personal-skill-candidate-1.0.json",
  "title": "PersonalSkillCandidate 1.0",
  "type": "object",
  "required": ["schema_version", "candidate_id", "name", "purpose", "triggers", "preconditions", "procedure", "tools", "outputs", "evaluator", "failure_modes", "source_lineage", "personal_adaptations", "real_world_evidence", "regression_tests", "confidence", "promotion_status"],
  "properties": {
    "schema_version": {"const": "1.0", "type": "string"},
    "candidate_id": {"type": "string"},
    "name": {"type": "string", "minLength": 1},
    "purpose": {"type": "string", "minLength": 1},
    "triggers": {"type": "array", "minItems": 1},
    "preconditions": {"type": "array"},
    "procedure": {"type": "array", "minItems": 1},
    "tools": {"type": "array"},
    "outputs": {"type": "array", "minItems": 1},
    "evaluator": {"type": "object"},
    "failure_modes": {"type": "array", "minItems": 1},
    "source_lineage": {"type": "object", "required": ["mentor_package_id", "teacher_rules_used", "evidence_pointers"]},
    "personal_adaptations": {"type": "object", "required": ["changes", "rationale", "episode_evidence"]},
    "real_world_evidence": {"type": "array"},
    "regression_tests": {"type": "array", "minItems": 1},
    "confidence": {"enum": ["candidate", "provisional", "validated"], "type": "string"},
    "promotion_status": {"enum": ["watch", "revise", "ready", "promoted", "rejected"], "type": "string"}
  }
}
