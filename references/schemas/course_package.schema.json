{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lineage-skill.local/schemas/course-package-1.0.json",
  "title": "Lineage CoursePackage 1.0",
  "type": "object",
  "required": ["schema_version", "manifest", "sources", "lessons", "claims", "concepts", "methods", "evidence", "quality"],
  "properties": {
    "schema_version": {"const": "1.0", "type": "string"},
    "manifest": {"type": "object", "required": ["course_id", "course_name"]},
    "sources": {"type": "array", "items": {"type": "object", "required": ["id", "path", "kind"]}},
    "lessons": {"type": "array", "items": {"type": "object", "required": ["id", "title"]}},
    "claims": {"type": "array", "items": {"type": "object", "required": ["id", "text", "provenance", "evidence"]}},
    "concepts": {"type": "array", "items": {"type": "object", "required": ["id", "title", "summary", "provenance", "evidence"]}},
    "topics": {"type": "array"},
    "cases": {"type": "array"},
    "methods": {"type": "array"},
    "diagnostics": {"type": "array"},
    "workflows": {"type": "array"},
    "rubrics": {"type": "array"},
    "templates": {"type": "array"},
    "transfer_rules": {"type": "array"},
    "failure_modes": {"type": "array"},
    "boundaries": {"type": "array"},
    "quotes": {"type": "array"},
    "learning_checks": {"type": "array"},
    "study_paths": {"type": "array"},
    "teacher_model_ref": {"type": "string"},
    "capability_graph_ref": {"type": "string"},
    "practice_bank_ref": {"type": "string"},
    "assessment_bank_ref": {"type": "string"},
    "evidence": {"type": "array", "items": {"type": "object", "required": ["id", "source_id", "path", "confidence", "evidence_kind"]}},
    "quality": {"type": "object", "required": ["coverage", "integrity", "mentor_readiness"]}
  }
}
